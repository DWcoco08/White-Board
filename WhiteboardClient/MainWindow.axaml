<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WhiteboardClient"
        x:Class="WhiteboardClient.MainWindow"
        Width="1060" Height="700"
        Title="Whiteboard cộng tác — LAN TCP Socket">

  <Window.Styles>
    <!-- nhãn trên thanh tối -->
    <Style Selector="TextBlock.barlabel">
      <Setter Property="Foreground" Value="#E6E6E6"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- tiêu đề mục trong sidebar sáng -->
    <Style Selector="TextBlock.head">
      <Setter Property="Foreground" Value="#1A1A1A"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <!-- nút nhấn chính (xanh) -->
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#0078D7"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
  </Window.Styles>

  <DockPanel>

    <!-- thanh kết nối -->
    <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="8,6">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Classes="barlabel" Text="Server:"/>
        <TextBox x:Name="HostBox" Width="110" Watermark="127.0.0.1"/>
        <TextBlock Classes="barlabel" Text="Cổng:"/>
        <TextBox x:Name="PortBox" Width="55" Watermark="5000"/>
        <TextBlock Classes="barlabel" Text="Tên:"/>
        <TextBox x:Name="UserBox" Width="90" Watermark="tên của bạn"/>
        <TextBlock Classes="barlabel" Text="Phòng:"/>
        <TextBox x:Name="RoomBox" Width="110" Watermark="tên phòng"/>
        <Button x:Name="ConnectBtn" Content="Kết nối" Click="OnConnectClick" Classes="accent"/>
        <Button x:Name="LeaveBtn" Content="Rời phòng" Click="OnLeaveClick" IsEnabled="False"
                Background="#5A5A5E" Foreground="White"/>
        <TextBlock x:Name="StatusText" Text="Chưa kết nối" Foreground="#FFD479"
                   VerticalAlignment="Center" Margin="8,0,0,0"/>
      </StackPanel>
    </Border>

    <!-- sidebar phải -->
    <Border DockPanel.Dock="Right" Width="250" Background="#ECECEC" Padding="10">
      <DockPanel>

        <!-- công cụ vẽ -->
        <StackPanel DockPanel.Dock="Top" Spacing="4">
          <TextBlock Classes="head" Text="Công cụ vẽ"/>
          <ComboBox x:Name="ShapeBox" SelectedIndex="0" HorizontalAlignment="Stretch">
            <ComboBoxItem>Đường thẳng</ComboBoxItem>
            <ComboBoxItem>Hình chữ nhật</ComboBoxItem>
            <ComboBoxItem>Hình tròn</ComboBoxItem>
            <ComboBoxItem>Bút tự do</ComboBoxItem>
          </ComboBox>

          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Classes="head" Text="Màu" VerticalAlignment="Center"/>
            <ComboBox x:Name="ColorBox" SelectedIndex="0" Width="86">
              <ComboBoxItem>#000000</ComboBoxItem>
              <ComboBoxItem>#E81123</ComboBoxItem>
              <ComboBoxItem>#0078D7</ComboBoxItem>
              <ComboBoxItem>#107C10</ComboBoxItem>
              <ComboBoxItem>#FF8C00</ComboBoxItem>
            </ComboBox>
            <TextBlock Classes="head" Text="Nét" VerticalAlignment="Center"/>
            <ComboBox x:Name="ThickBox" SelectedIndex="1" Width="52">
              <ComboBoxItem>1</ComboBoxItem>
              <ComboBoxItem>2</ComboBoxItem>
              <ComboBoxItem>4</ComboBoxItem>
              <ComboBoxItem>6</ComboBoxItem>
            </ComboBox>
          </StackPanel>

          <Button x:Name="ClearBtn" Content="Xóa bảng" Click="OnClearClick"
                  HorizontalAlignment="Left" Padding="12,4" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- chat ở đáy -->
        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,120,Auto" Margin="0,8,0,0">
          <TextBlock Grid.Row="0" Classes="head" Text="Chat"/>
          <Border Grid.Row="1" Background="White" BorderBrush="#CCC" BorderThickness="1" Margin="0,2,0,0">
            <ScrollViewer x:Name="ChatScroll">
              <ItemsControl x:Name="ChatList" Margin="4"/>
            </ScrollViewer>
          </Border>
          <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
            <TextBox x:Name="ChatInput" Width="160" Watermark="Nhập tin nhắn..."
                     KeyDown="OnChatKeyDown"/>
            <Button Content="Gửi" Click="OnSendChatClick" Classes="accent"/>
          </StackPanel>
        </Grid>

        <!-- thành viên (lấp phần giữa) -->
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Classes="head" Text="Thành viên"/>
          <Button DockPanel.Dock="Top" x:Name="PermBtn" Content="Khóa/Mở quyền vẽ"
                  Click="OnTogglePermClick" HorizontalAlignment="Left" Padding="12,4"
                  Margin="0,2,0,4" IsVisible="False"/>
          <Border Background="White" BorderBrush="#CCC" BorderThickness="1">
            <ListBox x:Name="MemberList" SelectionChanged="OnMemberSelected"/>
          </Border>
        </DockPanel>

      </DockPanel>
    </Border>

    <!-- vùng vẽ ở giữa -->
    <Border Background="#DDDDDD" Padding="8">
      <Border x:Name="BoardHost" BorderBrush="#888" BorderThickness="1" Background="White">
        <local:WhiteboardCanvas x:Name="Board" ClipToBounds="True"/>
      </Border>
    </Border>

  </DockPanel>
</Window>
